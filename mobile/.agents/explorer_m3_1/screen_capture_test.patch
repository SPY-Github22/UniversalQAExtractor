diff --git a/test/services/screen_capture_test.dart b/test/services/screen_capture_test.dart
index abcdefg..1234567 100644
--- a/test/services/screen_capture_test.dart
+++ b/test/services/screen_capture_test.dart
@@ -182,4 +182,59 @@ void main() {
     expect(() => service.startCapture(y: -1), throwsArgumentError);
     expect(service.isCapturing, isFalse);
   });
+
+  test('TC-T2-F1-06: Safe Dispose Prevents Late Event Crash', () async {
+    await service.startCapture();
+    service.dispose();
+
+    // Simulate frame after dispose
+    final testFrame = Uint8List.fromList([0x00, 0x01]);
+    expect(() => simulateNativeFrame(testFrame), returnsNormally);
+
+    // Simulate error after dispose
+    expect(() => simulateNativeError(), returnsNormally);
+  });
+
+  test('TC-T2-F1-07: Concurrent Start/Stop Serialization', () async {
+    final futures = Future.wait([
+      service.startCapture(),
+      service.stopCapture(),
+    ]);
+
+    final results = await futures;
+    expect(results[0], isTrue); // startCapture succeeded
+    expect(results[1], isTrue); // stopCapture succeeded
+    expect(service.isCapturing, isFalse); // Should be stopped in the end
+
+    // Verify that startCapture was called before stopCapture
+    expect(methodCallLog.length, 2);
+    expect(methodCallLog[0].method, 'startCapture');
+    expect(methodCallLog[1].method, 'stopCapture');
+  });
+
+  test('TC-T2-F1-08: checkIsCapturing Syncs Stream Subscription', () async {
+    final List<Uint8List> receivedFrames = [];
+    final subscription = service.frameStream.listen((frame) {
+      receivedFrames.add(frame);
+    });
+
+    // Bypassing startCapture to simulate native state change (e.g. background capture active)
+    isCapturingMock = true;
+
+    final statusActive = await service.checkIsCapturing();
+    expect(statusActive, isTrue);
+    expect(service.isCapturing, isTrue);
+
+    // Simulate frame and check if it is received
+    final testFrame = Uint8List.fromList([0x0A]);
+    simulateNativeFrame(testFrame);
+    await Future<void>.delayed(Duration.zero);
+    expect(receivedFrames.length, 1);
+    expect(receivedFrames[0], equals(testFrame));
+
+    // Simulate native capture stopping
+    isCapturingMock = false;
+    final statusInactive = await service.checkIsCapturing();
+    expect(statusInactive, isFalse);
+    expect(service.isCapturing, isFalse);
+
+    // Simulate frame and check that it is NOT received
+    receivedFrames.clear();
+    simulateNativeFrame(testFrame);
+    await Future<void>.delayed(Duration.zero);
+    expect(receivedFrames, isEmpty);
+
+    await subscription.cancel();
+  });
 }
